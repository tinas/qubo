{
  "name": "qubo",
  "version": "0.3.0",
  "description": "MongoDB-inspired query engine for JSON collections.",
  "keywords": [
    "filter",
    "javascript",
    "mongodb",
    "query",
    "query-builder",
    "search",
    "typescript",
    "zero-dependencies"
  ],
  "homepage": "https://github.com/tinas/qubo#readme",
  "bugs": {
    "url": "https://github.com/tinas/qubo/issues"
  },
  "license": "MIT",
  "author": "Ahmet Tinastepe <ahmettinastepe0@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tinas/qubo.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@typescript/native-preview": "7.0.0-dev.20260509.2",
    "bumpp": "^11.1.0",
    "typescript": "^6.0.3",
    "vite-plus": "catalog:"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.10.0",
      "onFail": "download"
    }
  }
}
